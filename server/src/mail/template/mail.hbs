<!DOCTYPE html>
<html>

<head>
    <title>Mail</title>
    <meta charset="UTF-8">
</head>


<body
    style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji';">
    <table style="width: 100%; padding: 1rem; background-color: #f2f2f2;">
        <tr>
            <td>
                <table align="center"
                    style="background-color: #fff; border-radius: 5px; padding: 1rem; width: 500px; margin:1rem auto 0">
                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 20px; padding:0.5rem 0; font-weight: bold;">
                                {{name}}</div>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" style="margin: 1rem; border-top: 1px solid rgba(5, 5, 5, 0.06);"></td>
                    </tr>

                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 16px; padding:0.5rem 0;">Loại đề nghị: {{type}}
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 16px; padding:0.5rem 0;">Giảng viên tạo: {{sender}}
                                ({{email}})
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 16px; padding:0.5rem 0;">Đơn vị: {{unit}}</div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 16px; padding:0.5rem 0;">Nơi sử dụng:
                                {{currentRoom}}</div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 16px; padding:0.5rem 0;">Tên thiết bị: {{device}}
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 16px; padding:0.5rem 0;">Tình trạng: {{type}}</div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div style="text-align: left; font-size: 16px; padding:0.5rem 0;">
                                <img src="{{image}}" alt="Image"
                                    style="max-width: 100%; height: auto; border-radius: 5px;" />
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" style="margin: 1rem; border-top: 1px solid rgba(5, 5, 5, 0.06);"></td>
                    </tr>

                    <tr>
                        <td colspan="2" style="text-align: center;">
                            <a href="https://qttb.vlute.edu.vn/quan-tri/de-nghi/" target="_blank"
                                style="display: inline-block; width: 100%; height: 40px; line-height: 40px; cursor: pointer; border-radius: 5px; background-color: #ed1b2f; color: #fff; border: none; outline: none; text-decoration: none; font-size: 16px;">
                                Xem tất cả đề nghị
                            </a>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2">
                            <div style="padding-top: 20px; text-align: left; font-size: 16px;">Trân trọng,</div>
                            <div style="text-align: left; font-size: 16px;">Phòng Quản trị - Thiết bị.</div>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>

</html>